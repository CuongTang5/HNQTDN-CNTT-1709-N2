<?xml version="1.0" encoding="utf-8"?>
<odoo><data>

    <record id="view_hop_dong_form" model="ir.ui.view">
        <field name="name">hop_dong_form</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <form string="Hợp Đồng Lao Động">
                <header>
                    <field name="trang_thai" widget="statusbar"
                           statusbar_visible="active,expired,terminated"/>
                </header>
                <sheet>
                    <!-- Cảnh báo -->
                    <div class="alert alert-warning d-flex align-items-center gap-2" role="alert"
                         attrs="{'invisible': ['|', ('thoi_han_con_lai', '&gt;', 30), ('thoi_han_con_lai', '&lt;', 0)]}">
                        <i class="fa fa-exclamation-triangle fa-lg"/>
                        <span>Hợp đồng sắp hết hạn trong <field name="thoi_han_con_lai" readonly="1" nolabel="1"/> ngày!</span>
                    </div>
                    <div class="alert alert-danger d-flex align-items-center gap-2" role="alert"
                         attrs="{'invisible': [('thoi_han_con_lai', '&gt;=', 0)]}">
                        <i class="fa fa-times-circle fa-lg"/>
                        <span>Hợp đồng đã hết hạn!</span>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" placeholder="Số hợp đồng..."/></h1>
                        <div style="color:#6c757d;font-size:15px;margin-top:4px;">
                            <field name="nhan_vien_id" readonly="1"/>
                            <span> · </span>
                            <field name="loai_hop_dong" readonly="1"/>
                            <span> · </span>
                            <field name="trang_thai" widget="badge"
                                   decoration-success="trang_thai == 'active'"
                                   decoration-danger="trang_thai == 'expired'"
                                   decoration-muted="trang_thai == 'terminated'"/>
                        </div>
                    </div>

                    <group>
                        <group string="Thông Tin Hợp Đồng">
                            <field name="name"/>
                            <field name="nhan_vien_id"/>
                            <field name="loai_hop_dong"/>
                            <field name="trang_thai"/>
                        </group>
                        <group string="Thời Hạn">
                            <field name="ngay_bat_dau"/>
                            <field name="ngay_ket_thuc"/>
                            <field name="thoi_han_con_lai" readonly="1"
                                   style="font-weight:bold;color:#007bff;"/>
                        </group>
                    </group>

                    <group>
                        <group string="Lương &amp; Ngày Công">
                            <field name="luong_co_ban"
                                   style="font-size:16px;font-weight:bold;color:#28a745;"/>
                            <field name="so_ngay_cong_chuan"/>
                        </group>
                        <group string="Chế Độ Nghỉ Phép (ngày/năm)">
                            <field name="ngay_nghi_phep_toi_da"/>
                            <field name="so_ngay_nghi_om"/>
                            <field name="nghi_phep_dac_biet"/>
                            <field name="ngay_nghi_co_luong"/>
                            <field name="tu_dong_duyet"/>
                        </group>
                    </group>

                    <group string="Ghi Chú">
                        <field name="ghi_chu" nolabel="1" placeholder="Ghi chú thêm về hợp đồng..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hop_dong_tree" model="ir.ui.view">
        <field name="name">hop_dong_tree</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <tree string="Hợp Đồng"
                  decoration-success="trang_thai == 'active'"
                  decoration-danger="trang_thai == 'expired'"
                  decoration-muted="trang_thai == 'terminated'">
                <field name="name"/>
                <field name="nhan_vien_id"/>
                <field name="loai_hop_dong"/>
                <field name="ngay_bat_dau"/>
                <field name="ngay_ket_thuc"/>
                <field name="luong_co_ban"/>
                <field name="thoi_han_con_lai" string="Còn Lại (ngày)"/>
                <field name="trang_thai" widget="badge"
                       decoration-success="trang_thai == 'active'"
                       decoration-danger="trang_thai == 'expired'"
                       decoration-muted="trang_thai == 'terminated'"/>
            </tree>
        </field>
    </record>

    <record id="view_hop_dong_graph" model="ir.ui.view">
        <field name="name">hop_dong_graph</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <graph string="Thống Kê Hợp Đồng" type="pie">
                <field name="trang_thai" type="row"/>
            </graph>
        </field>
    </record>

    <record id="view_hop_dong_search" model="ir.ui.view">
        <field name="name">hop_dong_search</field>
        <field name="model">hop_dong</field>
        <field name="arch" type="xml">
            <search string="Tìm Hợp Đồng">
                <field name="name"/>
                <field name="nhan_vien_id"/>
                <separator/>
                <filter string="Đang Hiệu Lực" name="active" domain="[('trang_thai','=','active')]"/>
                <filter string="Hết Hạn" name="expired" domain="[('trang_thai','=','expired')]"/>
                <filter string="Đã Chấm Dứt" name="terminated" domain="[('trang_thai','=','terminated')]"/>
                <group expand="1" string="Nhóm Theo">
                    <filter string="Nhân Viên" name="group_nv" context="{'group_by': 'nhan_vien_id'}"/>
                    <filter string="Loại HĐ" name="group_loai" context="{'group_by': 'loai_hop_dong'}"/>
                    <filter string="Trạng Thái" name="group_tt" context="{'group_by': 'trang_thai'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hop_dong" model="ir.actions.act_window">
        <field name="name">Hợp Đồng</field>
        <field name="res_model">hop_dong</field>
        <field name="view_mode">tree,form,graph</field>
        <field name="search_view_id" ref="view_hop_dong_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</data></odoo>
