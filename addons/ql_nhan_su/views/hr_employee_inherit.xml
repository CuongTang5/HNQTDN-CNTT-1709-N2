<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <record id="view_hr_employee_inherit_form" model="ir.ui.view">
        <field name="name">hr.employee.inherit.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Thông Tin Bổ Sung" name="thong_tin_bo_sung">
                    <group>
                        <group string="Giấy Tờ Tùy Thân">
                            <field name="so_cccd"/>
                            <field name="ngay_cap"/>
                            <field name="noi_cap"/>
                        </group>
                        <group string="Thông Tin Khác">
                            <field name="que_quan"/>
                            <field name="so_nguoi_phu_thuoc" readonly="1"/>
                        </group>
                    </group>
                </page>
                <page string="Thân Nhân" name="than_nhan">
                    <field name="family_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="relationship"/>
                            <field name="birth_date"/>
                            <field name="is_dependent"/>
                            <field name="so_cccd"/>
                            <field name="ghi_chu"/>
                        </tree>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

</data>
</odoo>
