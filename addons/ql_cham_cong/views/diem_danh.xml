<?xml version="1.0" encoding="utf-8"?>
<odoo><data>

    <record id="view_diem_danh_form" model="ir.ui.view">
        <field name="name">diem_danh_form</field>
        <field name="model">diem_danh</field>
        <field name="arch" type="xml">
            <form string="Điểm Danh">
                <header>
                    <field name="trang_thai_diem_danh" widget="statusbar"
                           statusbar_visible="chua_diem_danh,dang_lam,hoan_thanh"/>
                </header>
                <sheet>
                    <!-- Banner trạng thái -->
                    <div class="alert alert-info d-flex align-items-center gap-2" role="alert"
                         attrs="{'invisible': [('gio_check_in', '!=', False)]}">
                        <i class="fa fa-clock-o fa-lg"/>
                        <span>Chưa check-in. Nhấn <strong>Check-In</strong> để bắt đầu ghi nhận.</span>
                    </div>
                    <div class="alert alert-success d-flex align-items-center gap-2" role="alert"
                         attrs="{'invisible': ['|', ('gio_check_in', '=', False), ('gio_check_out', '!=', False)]}">
                        <i class="fa fa-check-circle fa-lg"/>
                        <span>Đã check-in lúc <field name="gio_check_in" readonly="1" nolabel="1"/>. Nhấn <strong>Check-Out</strong> khi kết thúc.</span>
                    </div>
                    <div class="alert alert-warning d-flex align-items-center gap-2" role="alert"
                         attrs="{'invisible': [('gio_check_out', '=', False)]}">
                        <i class="fa fa-flag-checkered fa-lg"/>
                        <span>Hoàn thành! Tổng giờ làm: <field name="so_gio_lam" readonly="1" nolabel="1"/> giờ.</span>
                    </div>

                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Thông Tin Nhân Viên">
                            <field name="nhan_vien_id"/>
                            <field name="phong_ban_id" readonly="1"/>
                            <field name="ngay_lam_viec"/>
                            <field name="lich_lam_viec_id"/>
                            <field name="ca_lam_viec" readonly="1"/>
                        </group>
                        <group string="Kết Quả Điểm Danh">
                            <field name="gio_check_in" readonly="1"/>
                            <field name="gio_check_out" readonly="1"/>
                            <field name="so_gio_lam" readonly="1"
                                   style="font-weight:bold;font-size:16px;color:#28a745;"/>
                            <field name="trang_thai_diem_danh" readonly="1"/>
                        </group>
                    </group>

                    <group string="Ghi Chú">
                        <field name="ghi_chu" nolabel="1" placeholder="Ghi chú thêm..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="check_in_out" type="object"
                            string="  Check-In"
                            attrs="{'invisible': [('gio_check_in', '!=', False)]}"
                            class="btn-primary btn-lg"/>
                    <button name="check_in_out" type="object"
                            string="  Check-Out"
                            attrs="{'invisible': ['|', ('gio_check_in', '=', False), ('gio_check_out', '!=', False)]}"
                            class="btn-success btn-lg"/>
                    <button string="Đã Hoàn Thành"
                            attrs="{'invisible': [('gio_check_out', '=', False)]}"
                            class="btn-secondary" disabled="1"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_diem_danh_tree" model="ir.ui.view">
        <field name="name">diem_danh_tree</field>
        <field name="model">diem_danh</field>
        <field name="arch" type="xml">
            <tree string="Điểm Danh"
                  decoration-danger="trang_thai_diem_danh == 'muon'"
                  decoration-success="trang_thai_diem_danh == 'hoan_thanh'"
                  decoration-info="trang_thai_diem_danh == 'dang_lam'"
                  decoration-muted="trang_thai_diem_danh == 'chua_diem_danh'">
                <field name="nhan_vien_id"/>
                <field name="phong_ban_id"/>
                <field name="ngay_lam_viec"/>
                <field name="ca_lam_viec"/>
                <field name="gio_check_in"/>
                <field name="gio_check_out"/>
                <field name="so_gio_lam" string="Giờ Làm" sum="Tổng Giờ"/>
                <field name="trang_thai_diem_danh" widget="badge"
                       decoration-success="trang_thai_diem_danh == 'hoan_thanh'"
                       decoration-info="trang_thai_diem_danh == 'dang_lam'"
                       decoration-danger="trang_thai_diem_danh == 'muon'"
                       decoration-muted="trang_thai_diem_danh == 'chua_diem_danh'"/>
            </tree>
        </field>
    </record>

    <record id="view_diem_danh_graph" model="ir.ui.view">
        <field name="name">diem_danh_graph</field>
        <field name="model">diem_danh</field>
        <field name="arch" type="xml">
            <graph string="Thống Kê Điểm Danh" type="bar">
                <field name="nhan_vien_id" type="row"/>
                <field name="so_gio_lam" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="diem_danh_search" model="ir.ui.view">
        <field name="name">diem_danh_search</field>
        <field name="model">diem_danh</field>
        <field name="arch" type="xml">
            <search string="Tìm Điểm Danh">
                <field name="nhan_vien_id" string="Nhân Viên"/>
                <field name="ngay_lam_viec" string="Ngày"/>
                <field name="phong_ban_id" string="Phòng Ban"/>
                <separator/>
                <filter string="Chưa Điểm Danh" name="chua"
                        domain="[('trang_thai_diem_danh','=','chua_diem_danh')]"/>
                <filter string="Đang Làm Việc" name="dang_lam"
                        domain="[('trang_thai_diem_danh','=','dang_lam')]"/>
                <filter string="Đi Muộn" name="muon"
                        domain="[('trang_thai_diem_danh','=','muon')]"/>
                <filter string="Hoàn Thành" name="hoan_thanh"
                        domain="[('trang_thai_diem_danh','=','hoan_thanh')]"/>
                <separator/>
                <filter string="Hôm Nay" name="hom_nay"
                        domain="[('ngay_lam_viec','=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="1" string="Nhóm Theo">
                    <filter string="Nhân Viên" name="group_nv" context="{'group_by': 'nhan_vien_id'}"/>
                    <filter string="Phòng Ban" name="group_pb" context="{'group_by': 'phong_ban_id'}"/>
                    <filter string="Ngày" name="group_ngay" context="{'group_by': 'ngay_lam_viec:day'}"/>
                    <filter string="Trạng Thái" name="group_tt" context="{'group_by': 'trang_thai_diem_danh'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_diem_danh" model="ir.actions.act_window">
        <field name="name">Điểm Danh</field>
        <field name="res_model">diem_danh</field>
        <field name="view_mode">tree,form,graph</field>
        <field name="search_view_id" ref="diem_danh_search"/>
        <field name="context">{'search_default_hom_nay': 1}</field>
    </record>

</data></odoo>
